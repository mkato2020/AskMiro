# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ── AI Provider ───────────────────────────────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=                # optional, leave blank

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ── Database ──────────────────────────────────────────────────
# Leave blank → uses local SQLite (development)
# Set to Supabase/Render Postgres URL → uses Postgres (production)
DATABASE_URL=
# Legacy local Postgres DSN (only needed if running local PG)
PG_DSN=dbname=askmiro_warehouse host=localhost

# ── GAS Bridge ────────────────────────────────────────────────
GAS_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GAS_TOKEN=your_gas_token_here
CRM_MIN_SCORE=65
CRM_BATCH_SIZE=25
CRM_DAILY_LIMIT=50

# ── Auth (Google OAuth) ──────────────────────────────────────
AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-to-random-string
AUTH_ALLOWED_EMAILS=*

# ── UI Mode ─────────────────────────────────────────────────
UI_MODE=react

# ── External data connectors (optional) ──────────────────────
COMPANIES_HOUSE_API_KEY=
CONTRACTS_FINDER_CLIENT_ID=
CONTRACTS_FINDER_CLIENT_SECRET=
CHARITY_COMMISSION_API_KEY=
CQC_SUBSCRIPTION_KEY=

# ── Email Deliverability Guard ────────────────────────────────
EMAIL_DAILY_LIMIT=50          # max emails per day (protect domain reputation)
EMAIL_PER_MINUTE_LIMIT=5      # max emails per minute (pacing)
EMAIL_ROLE_ACTION=flag         # "flag" (allow with warning) or "block" (reject role emails like info@)
OUTREACH_FROM_EMAIL=office@askmiro.com   # sender "from" address (must be configured as Gmail alias)
OUTREACH_FROM_NAME=Mike Kato             # personal display name (recipients see "Mike Kato <office@askmiro.com>")

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
